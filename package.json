{
  "name": "lit-gated-interactive-learning-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Open-source Lit tutorial/template for progressive access in interactive learning modules, with a NASA Mars mission reference demo.",
  "license": "MIT",
  "scripts": {
    "demo": "node src/demo.mjs",
    "test": "node src/demo.mjs --assert",
    "render": "node src/render-page.mjs",
    "lit:plan": "node src/lit-plan.mjs",
    "verify": "npm test && npm run render && npm run lit:plan",
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "keywords": [
    "lit-protocol",
    "interactive-learning",
    "progressive-access",
    "developer-education",
    "nasa",
    "ai-context-gating"
  ],
  "dependencies": {
    "@lit-protocol/constants": "^7.4.0",
    "@lit-protocol/encryption": "^7.4.0",
    "@lit-protocol/lit-node-client": "^7.4.0"
  },
  "devDependencies": {
    "@esbuild-plugins/node-globals-polyfill": "^0.2.3",
    "@esbuild-plugins/node-modules-polyfill": "^0.2.2",
    "rollup-plugin-polyfill-node": "^0.13.0",
    "vite": "^8.0.12"
  }
}
